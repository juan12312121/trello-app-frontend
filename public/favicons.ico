<svg width="100%" viewBox="0 0 256 256" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#6B7280;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#4B5563;stop-opacity:1" />
    </linearGradient>
    
    <filter id="shadow">
      <feGaussianBlur in="SourceAlpha" stdDeviation="1.5"/>
      <feOffset dx="0" dy="1" result="offsetblur"/>
      <feComponentTransfer>
        <feFuncA type="linear" slope="0.2"/>
      </feComponentTransfer>
      <feMerge>
        <feMergeNode/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>
  
  <!-- Fondo redondeado gris sofisticado -->
  <rect width="256" height="256" rx="60" fill="url(#bgGrad)"/>
  
  <!-- Accent sutil en esquina -->
  <ellipse cx="20" cy="20" rx="90" ry="90" fill="#8B5CF6" opacity="0.08"/>
  
  <!-- Tablero compacto - 3 columnas -->
  <g filter="url(#shadow)">
    
    <!-- Columna 1 - TO DO -->
    <g>
      <rect x="28" y="50" width="60" height="150" rx="6" fill="#FFFFFF" opacity="0.1" stroke="#FFFFFF" stroke-width="0.5" stroke-opacity="0.15"/>
      
      <!-- Tarjeta 1 -->
      <rect x="34" y="57" width="48" height="30" rx="4" fill="#F5F3FF" opacity="0.95"/>
      <rect x="39" y="61" width="26" height="1.8" rx="1" fill="#44403C" opacity="0.85"/>
      <rect x="39" y="66" width="20" height="1" rx="0.5" fill="#D7D3D0"/>
      <rect x="39" y="69" width="22" height="1" rx="0.5" fill="#D7D3D0"/>
      <circle cx="54" cy="62" r="1.8" fill="#A78BFA"/>
      
      <!-- Tarjeta 2 -->
      <rect x="34" y="91" width="48" height="30" rx="4" fill="#F5F3FF" opacity="0.95"/>
      <rect x="39" y="95" width="28" height="1.8" rx="1" fill="#44403C" opacity="0.85"/>
      <rect x="39" y="100" width="22" height="1" rx="0.5" fill="#D7D3D0"/>
      <rect x="39" y="103" width="18" height="1" rx="0.5" fill="#D7D3D0"/>
      <circle cx="54" cy="96" r="1.8" fill="#C4B5FD"/>
      
      <!-- Tarjeta 3 -->
      <rect x="34" y="125" width="48" height="30" rx="4" fill="#F5F3FF" opacity="0.95"/>
      <rect x="39" y="129" width="25" height="1.8" rx="1" fill="#44403C" opacity="0.85"/>
      <rect x="39" y="134" width="20" height="1" rx="0.5" fill="#D7D3D0"/>
      <rect x="39" y="137" width="23" height="1" rx="0.5" fill="#D7D3D0"/>
      <circle cx="54" cy="130" r="1.8" fill="#A78BFA"/>
    </g>
    
    <!-- Columna 2 - IN PROGRESS -->
    <g>
      <rect x="98" y="50" width="60" height="150" rx="6" fill="#FFFFFF" opacity="0.1" stroke="#FFFFFF" stroke-width="0.5" stroke-opacity="0.15"/>
      
      <!-- Tarjeta 1 -->
      <rect x="104" y="57" width="48" height="30" rx="4" fill="#F5F5F4" opacity="0.95"/>
      <rect x="109" y="61" width="30" height="1.8" rx="1" fill="#44403C" opacity="0.85"/>
      <rect x="109" y="66" width="22" height="1" rx="0.5" fill="#D7D3D0"/>
      <rect x="109" y="69" width="26" height="1" rx="0.5" fill="#D7D3D0"/>
      <!-- Barra de progreso -->
      <rect x="109" y="74" width="30" height="1.5" rx="0.75" fill="#E7E5E4"/>
      <rect x="109" y="74" width="15" height="1.5" rx="0.75" fill="#78716C"/>
      
      <!-- Tarjeta 2 -->
      <rect x="104" y="91" width="48" height="30" rx="4" fill="#F5F5F4" opacity="0.95"/>
      <rect x="109" y="95" width="26" height="1.8" rx="1" fill="#44403C" opacity="0.85"/>
      <rect x="109" y="100" width="24" height="1" rx="0.5" fill="#D7D3D0"/>
      <rect x="109" y="103" width="20" height="1" rx="0.5" fill="#D7D3D0"/>
      <rect x="109" y="108" width="30" height="1.5" rx="0.75" fill="#E7E5E4"/>
      <rect x="109" y="108" width="22" height="1.5" rx="0.75" fill="#78716C"/>
      
      <!-- Tarjeta 3 -->
      <rect x="104" y="125" width="48" height="30" rx="4" fill="#F5F5F4" opacity="0.95"/>
      <rect x="109" y="129" width="28" height="1.8" rx="1" fill="#44403C" opacity="0.85"/>
      <rect x="109" y="134" width="20" height="1" rx="0.5" fill="#D7D3D0"/>
      <rect x="109" y="137" width="24" height="1" rx="0.5" fill="#D7D3D0"/>
      <rect x="109" y="142" width="30" height="1.5" rx="0.75" fill="#E7E5E4"/>
      <rect x="109" y="142" width="10" height="1.5" rx="0.75" fill="#78716C"/>
    </g>
    
    <!-- Columna 3 - DONE -->
    <g>
      <rect x="168" y="50" width="60" height="150" rx="6" fill="#FFFFFF" opacity="0.1" stroke="#FFFFFF" stroke-width="0.5" stroke-opacity="0.15"/>
      
      <!-- Tarjeta 1 completada -->
      <rect x="174" y="57" width="48" height="30" rx="4" fill="#F0FDF4" opacity="0.95"/>
      <line x1="179" y1="61" x2="210" y2="61" stroke="#D7D3D0" stroke-width="1.2" opacity="0.6"/>
      <rect x="179" y="66" width="20" height="1" rx="0.5" fill="#D7D3D0" opacity="0.5"/>
      <rect x="179" y="69" width="22" height="1" rx="0.5" fill="#D7D3D0" opacity="0.5"/>
      <!-- Checkmark -->
      <g stroke="#6BBF7A" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <path d="M 220 61 L 221.5 62.5 L 224 59"/>
      </g>
      
      <!-- Tarjeta 2 completada -->
      <rect x="174" y="91" width="48" height="30" rx="4" fill="#F0FDF4" opacity="0.95"/>
      <line x1="179" y1="95" x2="210" y2="95" stroke="#D7D3D0" stroke-width="1.2" opacity="0.6"/>
      <rect x="179" y="100" width="22" height="1" rx="0.5" fill="#D7D3D0" opacity="0.5"/>
      <rect x="179" y="103" width="18" height="1" rx="0.5" fill="#D7D3D0" opacity="0.5"/>
      <g stroke="#6BBF7A" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <path d="M 220 95 L 221.5 96.5 L 224 93"/>
      </g>
      
      <!-- Tarjeta 3 completada -->
      <rect x="174" y="125" width="48" height="30" rx="4" fill="#F0FDF4" opacity="0.95"/>
      <line x1="179" y1="129" x2="210" y2="129" stroke="#D7D3D0" stroke-width="1.2" opacity="0.6"/>
      <rect x="179" y="134" width="20" height="1" rx="0.5" fill="#D7D3D0" opacity="0.5"/>
      <rect x="179" y="137" width="23" height="1" rx="0.5" fill="#D7D3D0" opacity="0.5"/>
      <g stroke="#6BBF7A" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <path d="M 220 129 L 221.5 130.5 L 224 127"/>
      </g>
    </g>
    
  </g>
  
  <!-- Marco sutil superior -->
  <rect x="10" y="10" width="236" height="236" rx="50" fill="none" stroke="#FFFFFF" stroke-width="1" opacity="0.12"/>
</svg>